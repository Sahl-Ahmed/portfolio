# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE SEARCH CONSOLE CONFIGURATION (PLACEHOLDERS)
# Google Search Console site-verification meta tag content (e.g. g-xxxxx...)
VITE_GSC_VERIFICATION_META=""
# Name of the Google Search Console HTML verification file (e.g. google1234567.html)
VITE_GSC_VERIFICATION_HTML_FILE=""
# Exact text inside the HTML verification file
VITE_GSC_VERIFICATION_HTML_CONTENT=""
# DNS TXT record for Google Search Console verification
VITE_GSC_DNS_RECORD=""

# BING WEBMASTER TOOLS CONFIGURATION (PLACEHOLDERS)
# Bing Verification meta tag content (msvalidate.01)
VITE_BING_VERIFICATION_META=""
# Name of the Bing XML site authorization file (normally BingSiteAuth.xml)
VITE_BING_VERIFICATION_XML_FILE=""
# Exact contents inside the Bing verification XML file
VITE_BING_VERIFICATION_XML_CONTENT=""
# DNS TXT record for Bing verification
VITE_BING_DNS_RECORD=""

# GOOGLE ANALYTICS 4
# Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=""

# MICROSOFT CLARITY
# Clarity Project ID (e.g. abcdefghij)
VITE_CLARITY_PROJECT_ID=""

# INDEXNOW INTEGRATION
# IndexNow API key (minimum 8 character hex string)
VITE_INDEXNOW_API_KEY=""

# CLOUDFLARE WORKER AI PROXY MIGRATION (PHASE 2)
# Configures the backend URL of the Cloudflare Worker secure proxy.
# If left blank, the frontend continues using server.ts directly.
VITE_AI_BACKEND_URL=""

